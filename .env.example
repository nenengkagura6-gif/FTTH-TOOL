# Environment Configuration

# Server Configuration
PORT=8000
DEBUG=false

# CORS Settings (for Cloudflare)
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Upload Settings
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
MAX_FILES_PER_REQUEST=10

# Geocoding Settings
NOMINATIM_TIMEOUT=30
NOMINATIM_DELAY=1.2
NOMINATIM_USER_AGENT="KML_Processing_API"

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json